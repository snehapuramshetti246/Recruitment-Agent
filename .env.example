# .env.example — Copy this to .env and fill in your values.
# Never commit .env to version control.

# ── LLM Provider — GitHub Models ──────────────────────────────────────────
# GitHub Personal Access Token (https://github.com/settings/tokens)
# No special scopes required for GitHub Models access.
GITHUB_TOKEN=your_github_personal_access_token_here

# Model to use from GitHub Models marketplace
# Browse available models: https://github.com/marketplace/models
LLM_MODEL=gpt-4o-mini
# LLM_MODEL=gpt-4o
# LLM_MODEL=Meta-Llama-3.3-70B-Instruct
# LLM_MODEL=Mistral-small

# ── LangSmith (optional observability) ────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=techvest-recruitment-agent

# ── Agent safety limits ────────────────────────────────────────────────────
AGENT_STEP_CAP=25
AGENT_RECURSION_LIMIT=50

# ── Audit log ─────────────────────────────────────────────────────────────
AUDIT_LOG_PATH=decisions.json
